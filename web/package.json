{
  "name": "kweaver-web",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:dip": "pnpm --filter @kweaver-web/dip dev",
