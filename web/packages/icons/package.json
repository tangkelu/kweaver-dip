{
  "name": "@kweaver-web/icons",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "download": "tsx scripts/download.ts",
    "build:icons": "tsx scripts/build.ts",
    "build:lib": "tsup --config tsup.config.ts",
    "build": "pnpm download && pnpm build:icons && pnpm build:lib",
    "preview": "vite --config vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "prepublishOnly": "pnpm test && pnpm build && pnpm typecheck"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@kweaver-web/tsconfig": "workspace:*",
    "@kweaver-web/tsup-config": "workspace:*",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "svgo": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
