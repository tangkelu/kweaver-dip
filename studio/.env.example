PORT=3000

OPENCLAW_GATEWAY_PROTOCOL=ws            # 必填，OpenClaw 网关协议
OPENCLAW_GATEWAY_HOST=127.0.0.1         # 必填，OpenClaw 网关地址
OPENCLAW_GATEWAY_PORT=19001             # 必填，OpenClaw 网关端口
OPENCLAW_GATEWAY_TOKEN=                 # 必填，OpenClaw 网关认证 Token
OPENCLAW_GATEWAY_TIMEOUT_MS=5000

OPENCLAW_ROOT_DIR=                      # 必填，OpenClaw 根目录，通常是 ~/.openclaw/
OPENCLAW_CONFIG_PATH=                   # 必填，openclaw.json 配置文件路径，通常是 {OPENCLAW_ROOT_DIR}/openclaw.json
OPENCLAW_WORKSPACE_DIR=                 # 必填，OpenClaw 工作目录，通常是 {OPENCLAW_ROOT_DIR}/workspace

KWEAVER_BASE_URL=                       # 可选，KWeaver 服务地址
KWEAVER_TOKEN=                          # 可选，KWeaver Token

# 以下配置仅在 NODE_ENV=development 时有效
OAUTH_MOCK_USER_ID=                     # 可选，用于开发环境的 OAuth 模拟用户 ID
KWEAVER_HYDRA_ADMIN_URL=                # 可选，Hydra 管理后台地址，用于 Token 内省
