{
  "name": "dip-studio-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DIP Studio backend service scaffold built with Express and TypeScript.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "init:agents": "node scripts/init_agents/index.mjs",
    "start": "node dist/server.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "multer": "^2.1.1",
    "openclaw": "2026.3.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
